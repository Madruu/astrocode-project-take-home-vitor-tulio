DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=postgres
DB_DATABASE=astrocode

# Mercado Pago test token from Developers > Test credentials (TEST-...)
MP_ACCESS_TOKEN=TEST-REPLACE_WITH_YOUR_TEST_ACCESS_TOKEN
MP_TEST_MODE=true

# URL used for returning from checkout (must load account page to auto-confirm)
MP_FRONTEND_URL=YOUR_URL

# Optional webhook URL (use ngrok/localtunnel when developing locally)
MP_NOTIFICATION_URL=
